{
  "expo": {
    "name": "오르다",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.seungyoonlee.orda",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A1C1E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "package": "com.seungyoonlee.orda"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1A1C1E",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "등반을 시작하면 정상까지 남은 거리·경과 시간을 잠금화면 위젯과 알림에 실시간으로 표시하기 위해 위치를 사용합니다. 추적은 등반 세션 중에만 하고, 종료하면 즉시 중단합니다.",
          "locationAlwaysAndWhenInUsePermission": "화면을 꺼도 안정적으로 진행 상황을 갱신하려면 '항상 허용'을 선택하세요. 위치는 등반 세션 중에만 사용하며 서버로 전송하지 않습니다.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "@mj-studio/react-native-naver-map",
        {
          "client_id": "3mohcujert"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepos": [
              "https://repository.map.naver.com/archive/maven"
            ]
          }
        }
      ],
      [
        "expo-widgets",
        {
          "frequentUpdates": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fdbeb487-67d7-4b67-81d1-37f36352412f"
      }
    },
    "owner": "seungyoon-lee29"
  }
}
